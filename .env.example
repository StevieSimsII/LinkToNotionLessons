# Telegram
TELEGRAM_BOT_TOKEN=
# Only this numeric Telegram user ID is allowed to use the bot. Get yours from @userinfobot.
ALLOWED_TELEGRAM_USER_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Notion
# Create an integration at https://www.notion.so/my-integrations, share a parent page with it,
# then copy the page ID (the last 32 chars of the page URL, with or without dashes).
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# Gmail SMTP
# Create an app password at https://myaccount.google.com/apppasswords
# Multiple recipients are supported; separate them with commas or semicolons.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_TO=

# GitHub (optional — unauthenticated works for public repos but has a lower rate limit)
GITHUB_TOKEN=
